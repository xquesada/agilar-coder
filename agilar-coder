assess_framework_tracking() {
    local repo_root="$1"
    local score=0
    local max=4
    local details=""

    if [[ -f .agilar-coder.version ]]; then
        local installed_version
        installed_version="$(tr -d '\r' < .agilar-coder.version)"
        local current_version
        current_version="$(tr -d '\r' < "$repo_root/VERSION" 2>/dev/null || echo "unknown")"
        details+=".agilar-coder.version ✓"
        ((score++))
        if [[ "$installed_version" == "$current_version" ]]; then
            details+=" (current)  "
            ((score++))
        else
            details+=" (outdated: $installed_version → $current_version)  "
        fi
    else
        details="Not tracked  "
    fi

    if [[ -f VERSION ]]; then
        details+="VERSION ✓  "
        ((score++))
    else
        details+="VERSION ✗  "
    fi

    if [[ -f CHANGELOG.md ]]; then
        details+="CHANGELOG ✓"
        ((score++))
    else
        details+="CHANGELOG ✗"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "Framework Tracking" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ ! -f .agilar-coder.version ]]; then
        ASSESS_RECOMMENDATIONS+=("Track with agilar-coder               agilar-coder install (creates .agilar-coder.version)")
    elif [[ $score -le 2 ]]; then
        ASSESS_RECOMMENDATIONS+=("Upgrade agilar-coder                  agilar-coder upgrade")
    fi
    if [[ ! -f VERSION ]]; then
        ASSESS_RECOMMENDATIONS+=("Add VERSION file                      echo '1.0.0' > VERSION")
    fi
    if [[ ! -f CHANGELOG.md ]]; then
        ASSESS_RECOMMENDATIONS+=("Add CHANGELOG.md                      track changes per version (Keep a Changelog format)")
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Helpers
# ─────────────────────────────────────────────────────────────────────────────

# Ensure CLAUDE.md is a real file (not a symlink) and AGENTS.md/GEMINI.md
# are symlinks pointing TO it. Handles projects where the direction is
# reversed (e.g. CLAUDE.md → AGENTS.md) or where circular symlinks exist.
normalize_agent_guidance() {
    # Case 1: CLAUDE.md is a symlink
    if [[ -L CLAUDE.md ]]; then
        local target
        target="$(readlink CLAUDE.md)"
        if [[ -f "$target" && ! -L "$target" ]]; then
            # Target is a real file — replace symlink with the content
            rm CLAUDE.md
            cp "$target" CLAUDE.md
            echo "  Normalized: CLAUDE.md (was symlink to $target, now a real file)"
        else
            # Target is missing or also a symlink (circular) — remove broken symlink
            rm CLAUDE.md
            echo "  Removed: broken CLAUDE.md symlink"
        fi
    fi

    # Case 2: AGENTS.md is a real file but CLAUDE.md doesn't exist — rename it
    if [[ ! -f CLAUDE.md && -f AGENTS.md && ! -L AGENTS.md ]]; then
        mv AGENTS.md CLAUDE.md
        echo "  Normalized: renamed AGENTS.md → CLAUDE.md"
    fi

    # Now fix AGENTS.md / GEMINI.md to be symlinks TO CLAUDE.md (if CLAUDE.md exists)
    if [[ -f CLAUDE.md && ! -L CLAUDE.md ]]; then
        # AGENTS.md: replace real file or wrong-direction symlink with correct symlink
        if [[ -f AGENTS.md && ! -L AGENTS.md ]]; then
            # Real file — only replace if content matches CLAUDE.md (avoid data loss)
            if cmp -s CLAUDE.md AGENTS.md; then
                rm AGENTS.md
                ln -s CLAUDE.md AGENTS.md
                echo "  Normalized: AGENTS.md → CLAUDE.md (was duplicate file)"
            fi
        elif [[ -L AGENTS.md ]]; then
            local agents_target
            agents_target="$(readlink AGENTS.md)"
            if [[ "$agents_target" != "CLAUDE.md" ]]; then
                rm AGENTS.md
                ln -s CLAUDE.md AGENTS.md
                echo "  Normalized: AGENTS.md → CLAUDE.md (was pointing to $agents_target)"
            fi
        fi

        if [[ -L GEMINI.md ]]; then
            local gemini_target
            gemini_target="$(readlink GEMINI.md)"
            if [[ "$gemini_target" != "CLAUDE.md" ]]; then
                rm GEMINI.md
                ln -s CLAUDE.md GEMINI.md
                echo "  Normalized: GEMINI.md → CLAUDE.md (was pointing to $gemini_target)"
            fi
        fi
    fi
}

# Register agilar-coder SessionStart hook in .claude/settings.json
# Also patches Entire's hook to use a wrapper that shortens its message.
# Merges with existing hooks without overwriting them.
register_claude_hook() {
    local settings_file=".claude/settings.json"
    mkdir -p .claude

    # Install Entire wrapper if Entire is enabled in this repo and wrapper doesn't exist
    if command -v entire &>/dev/null && ! entire status 2>/dev/null | grep -q "not set up" && [[ ! -f .claude/hooks/entire-session-start.sh ]]; then
        mkdir -p .claude/hooks
        cat > .claude/hooks/entire-session-start.sh << 'ENTIRE_HOOK'
#!/bin/sh
entire hooks claude-code session-start 2>/dev/null | python3 -c "
import sys, json, subprocess
try:
    data = json.load(sys.stdin)
