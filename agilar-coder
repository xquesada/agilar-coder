    # VERSION file
    if [[ ! -f VERSION ]]; then
        printf '1.0.0\n' > VERSION
        echo "  Created: VERSION (1.0.0)"
    fi

    # CHANGELOG.md
    if [[ ! -f CHANGELOG.md ]]; then
        cat > CHANGELOG.md << CHANGELOG_EOF
# Changelog

All notable changes to this project are documented in this file.

Format follows [Keep a Changelog](https://keepachangelog.com/). Versions follow [Semantic Versioning](https://semver.org/).

## [Unreleased]

## [1.0.0] - $(date +%Y-%m-%d)

### Added
- Initial release
CHANGELOG_EOF
        echo "  Created: CHANGELOG.md"
    fi

    # Stack reference doc
    if [[ ! -f docs/stack-reference.md && ! -f TOOLCHAIN.md ]]; then
        local stack_name=""
        if [[ -f package.json ]]; then stack_name="node"
        elif [[ -f go.mod ]]; then stack_name="go"
        elif [[ -f pyproject.toml || -f setup.py ]]; then stack_name="python"
        elif [[ -f mix.exs ]]; then stack_name="elixir"
        fi
        if [[ -n "$stack_name" && -f "$repo_root/templates/stacks/$stack_name.md" ]]; then
            mkdir -p docs
            cp "$repo_root/templates/stacks/$stack_name.md" docs/stack-reference.md
            echo "  Created: docs/stack-reference.md"
        fi
    fi

    # Canonical skill docs if docs/skills/ doesn't exist
    if [[ ! -d docs/skills ]]; then
        mkdir -p docs/skills
        local docs_added=0
        for skill_dir in "$repo_root"/skills/*/; do
            [[ -d "$skill_dir" ]] || continue
            local sname
            sname="$(basename "$skill_dir")"
            if [[ -f "$skill_dir/SKILL.md" ]]; then
                cp "$skill_dir/SKILL.md" "docs/skills/$sname.md"
                ((docs_added++))
            fi
        done
        if [[ $docs_added -gt 0 ]]; then
            echo "  Created: docs/skills/ ($docs_added canonical references)"
        fi
    fi

    # Version tracking
    echo "$VERSION" > .agilar-coder.version
    echo "  Created: .agilar-coder.version ($VERSION)"

    # Claude Code startup hook
    register_claude_hook

    # Create PBIs for anything fill-gaps cannot do automatically
    local pbi_count=0
    mkdir -p backlog/ready

    if ! compgen -G ".github/workflows/*.yml" > /dev/null 2>&1 && \
       ! compgen -G ".github/workflows/*.yaml" > /dev/null 2>&1 && \
       [[ ! -f .gitlab-ci.yml ]] && \
       [[ ! -f Jenkinsfile ]] && \
       [[ ! -d .circleci ]] && \
       [[ ! -f bitbucket-pipelines.yml ]]; then
        cat > backlog/ready/setup-ci-pipeline.md << 'CI_PBI'
# Set up CI/CD pipeline

## Description
Add a continuous integration pipeline so tests and linting run automatically on every push.

## Steps
1. Choose a CI provider (GitHub Actions recommended)
2. Create a workflow file (e.g. `.github/workflows/ci.yml`)
3. Configure it to run the test and lint commands from CLAUDE.md
4. Verify the pipeline runs on the next push

## Acceptance Criteria
- CI runs on every push to main
- Tests and linting execute automatically
- Pipeline status is visible in the repository
CI_PBI
        echo "  Created: backlog/ready/setup-ci-pipeline.md"
        ((pbi_count++))
    fi

    echo ""
    if [[ $pbi_count -gt 0 ]]; then
        echo "Done. $pbi_count PBI(s) created in backlog/ready/ for the remaining gaps."
        echo "Complete them to reach 100% compliance."
    else
        echo "Done. Run 'agilar-coder assess' to verify 100% compliance."
    fi
