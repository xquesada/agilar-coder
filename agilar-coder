#!/usr/bin/env bash
#
# agilar-coder - Run Claude Code unattended on a Product Backlog
#

set -euo pipefail

# Colors (disabled if not a terminal)
if [[ -t 1 ]]; then
    RED='\033[0;31m'
    GREEN='\033[0;32m'
    YELLOW='\033[0;33m'
    NC='\033[0m'
else
    RED=''
    GREEN=''
    YELLOW=''
    NC=''
fi

CONFIG_DIR="$HOME/.agilar-coder"
CONFIG_FILE="$CONFIG_DIR/config.conf"
STATUS_FILE=".agilar-status"

# Default configuration values
DEFAULT_MODEL="opus"
DEFAULT_MAX_TURNS="100"
DEFAULT_VERBOSE="false"
DEFAULT_USER_PROMPT='Implement the next PBI of the Product Backlog [FILE_NAME]. When you are done with all tasks and all tests pass, commit the new feature and push if you know how to, and verify that the CI is green using the CLI if you know how to. Once everything passes, update the Product Backlog document to indicate the progress we achieved.'

# Fixed prompt (hardcoded)
FIXED_PROMPT='You are processing a Product Backlog. Your task:

1. Parse the provided backlog file and identify all PBIs (Product Backlog Items)
2. Find the FIRST PBI that is NOT marked as DONE
3. Implement that ONE PBI completely
4. Update the backlog file to mark that PBI as DONE
5. Write a status file ".agilar-status" in the current directory with:
   TOTAL=<total number of PBIs>
   REMAINING=<number of PBIs not yet DONE>
   LAST_PBI="<identifier or title of the PBI you just completed>"
   STATUS=<success|error>
   Note: Quote values containing spaces (e.g., LAST_PBI="PBI-001: My Feature")

If there are no PBIs, or all PBIs are already DONE, write:
   TOTAL=<count>
   REMAINING=0
   LAST_PBI=none
   STATUS=success

If the backlog is invalid or you encounter an error, write:
   STATUS=error
   ERROR=<description>

IMPORTANT: Work on exactly ONE PBI per execution. Do not continue to the next PBI.'

# ─────────────────────────────────────────────────────────────────────────────
# Self-location
# ─────────────────────────────────────────────────────────────────────────────

resolve_repo_root() {
    # Try resolving from script location
    local script_path
    script_path="$(cd "$(dirname "$0")" && pwd -P)/$(basename "$0")"
    if [[ -L "$script_path" ]]; then
        script_path="$(readlink "$script_path")"
        # Handle relative symlinks
        if [[ "$script_path" != /* ]]; then
            script_path="$(cd "$(dirname "$0")" && cd "$(dirname "$script_path")" && pwd -P)/$(basename "$script_path")"
        fi
    fi
    local repo_root
    repo_root="$(dirname "$script_path")"

    # Verify it's actually the agilar-coder repo (has skills/ and scaffold)
    if [[ -d "$repo_root/skills" && -f "$repo_root/scaffold" ]]; then
        echo "$repo_root"
        return 0
    fi

    # Fall back to AGILAR_CODER_HOME
    if [[ -n "${AGILAR_CODER_HOME:-}" && -d "$AGILAR_CODER_HOME/skills" ]]; then
        echo "$AGILAR_CODER_HOME"
        return 0
    fi

    echo "Error: Cannot find agilar-coder repo. Set AGILAR_CODER_HOME." >&2
    return 1
}

# ─────────────────────────────────────────────────────────────────────────────
# Prerequisite check
# ─────────────────────────────────────────────────────────────────────────────

check_claude_cli() {
    if ! command -v claude &>/dev/null; then
        echo -e "${RED}Error: Claude Code CLI not found in PATH${NC}"
        echo ""
        echo "  agilar-coder requires Claude Code to be installed and configured."
        echo "  Install: https://docs.anthropic.com/en/docs/claude-code"
        exit 1
    fi

    if ! claude --version &>/dev/null; then
        echo -e "${RED}Error: Claude Code CLI found but not responding${NC}"
        echo "  'claude --version' failed. Check your installation."
        exit 1
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Assessment helpers
# ─────────────────────────────────────────────────────────────────────────────

# Print a 10-char progress bar
progress_bar() {
    local pct="$1"
    local filled=$(( pct / 10 ))
    local empty=$(( 10 - filled ))
    local bar=""
    for ((i=0; i<filled; i++)); do bar+="█"; done
    for ((i=0; i<empty; i++)); do bar+="░"; done
    echo "$bar"
}

# Return color code based on percentage
score_color() {
    local pct="$1"
    if [[ $pct -ge 80 ]]; then echo -n "$GREEN"
    elif [[ $pct -ge 40 ]]; then echo -n "$YELLOW"
    else echo -n "$RED"
    fi
}

# Global arrays used by assess functions (set in cmd_assess)
# ASSESS_TOTAL_SCORE, ASSESS_TOTAL_MAX, ASSESS_RECOMMENDATIONS

# Print a dimension line: "  Name           ████░░░░░░  67%   details"
print_dimension() {
    local name="$1"
    local pct="$2"
    local details="$3"
    local bar
    bar="$(progress_bar "$pct")"
    local color
    color="$(score_color "$pct")"
    printf "  %-20s %s${color}%3d%%${NC}   %s\n" "$name" "$bar" "$pct" "$details"
}

assess_agent_guidance() {
    local score=0
    local max=3
    local details=""

    if [[ -f CLAUDE.md ]]; then
        details+="CLAUDE.md ✓  "
        ((score++))
    else
        details+="CLAUDE.md ✗  "
    fi

    if [[ -f AGENTS.md || -L AGENTS.md ]]; then
        details+="AGENTS.md ✓  "
        ((score++))
    else
        details+="AGENTS.md ✗  "
    fi

    if [[ -f GEMINI.md || -L GEMINI.md ]]; then
        details+="GEMINI.md ✓"
        ((score++))
    else
        details+="GEMINI.md ✗"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "Agent Guidance" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ ! -f CLAUDE.md ]]; then
        ASSESS_RECOMMENDATIONS+=("Create CLAUDE.md                      project context for AI agents")
    fi
    if [[ ! -f AGENTS.md && ! -L AGENTS.md && -f CLAUDE.md ]]; then
        ASSESS_RECOMMENDATIONS+=("Add AGENTS.md                         symlink to CLAUDE.md for multi-platform agents")
    fi
    if [[ ! -f GEMINI.md && ! -L GEMINI.md && -f CLAUDE.md ]]; then
        ASSESS_RECOMMENDATIONS+=("Add GEMINI.md                         symlink to CLAUDE.md for multi-platform agents")
    fi
}

assess_working_agreements() {
    local score=0
    local max=5
    local details=""

    # Build a search corpus from CLAUDE.md + docs/
    local corpus=""
    [[ -f CLAUDE.md ]] && corpus="$(cat CLAUDE.md)"
    if [[ -d docs ]]; then
        # Append text from docs/ md files (limit to avoid huge corpora)
        local doc_text
        doc_text="$(find docs -name '*.md' -maxdepth 3 -print0 2>/dev/null | xargs -0 head -q -n 200 2>/dev/null || true)"
        corpus="$corpus $doc_text"
    fi
    # Also check .claude/skills/ for skill names
    local skills_list=""
    if [[ -d .claude/skills ]]; then
        skills_list="$(ls .claude/skills/ 2>/dev/null)"
    fi

    # TDD
    if grep -qiE 'tdd|test.driven|write tests first' <<< "$corpus" 2>/dev/null || grep -q 'tdd' <<< "$skills_list" 2>/dev/null; then
        details+="TDD ✓  "
        ((score++))
    else
        details+="TDD ✗  "
    fi

    # Code review
    if grep -qiE 'code.review|review' <<< "$corpus" 2>/dev/null || grep -q 'code-review' <<< "$skills_list" 2>/dev/null; then
        details+="Review ✓  "
        ((score++))
    else
        details+="Review ✗  "
    fi

    # Verification
    if grep -qiE 'verification|verify|evidence' <<< "$corpus" 2>/dev/null || grep -q 'verification' <<< "$skills_list" 2>/dev/null; then
        details+="Verification ✓  "
        ((score++))
    else
        details+="Verification ✗  "
    fi

    # Debugging
    if grep -qiE 'debugging|root.cause' <<< "$corpus" 2>/dev/null || grep -q 'debugging' <<< "$skills_list" 2>/dev/null; then
        details+="Debug ✓  "
        ((score++))
    else
        details+="Debug ✗  "
    fi

    # Brainstorming
    if grep -qiE 'brainstorm|alternatives' <<< "$corpus" 2>/dev/null || grep -q 'brainstorming' <<< "$skills_list" 2>/dev/null; then
        details+="Brainstorm ✓"
        ((score++))
    else
        details+="Brainstorm ✗"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "Working Agreements" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ $score -lt $max ]]; then
        ASSESS_RECOMMENDATIONS+=("Strengthen working agreements          document TDD, review, verification, debugging, brainstorming in CLAUDE.md")
    fi
}

assess_quality_gates() {
    local score=0
    local max=2
    local details=""

    # Test command (documented or configured)
    if [[ -f Makefile ]] && grep -q 'test' Makefile 2>/dev/null; then
        details+="Tests ✓  "
        ((score++))
    elif [[ -f package.json ]] && grep -q '"test"' package.json 2>/dev/null; then
        details+="Tests ✓  "
        ((score++))
    elif [[ -f CLAUDE.md ]] && grep -qiE 'test command|run tests|npm test|go test|pytest|cargo test|mix test' CLAUDE.md 2>/dev/null; then
        details+="Tests ✓  "
        ((score++))
    else
        details+="Tests ✗  "
    fi

    # Lint command (config file or documented)
    if compgen -G ".eslintrc*" > /dev/null 2>&1 || \
       compgen -G "eslint.config*" > /dev/null 2>&1 || \
       [[ -f .golangci.yml || -f .golangci.yaml ]] || \
       [[ -f .pylintrc ]] || \
       ( [[ -f pyproject.toml ]] && grep -qE 'ruff|pylint|flake8' pyproject.toml 2>/dev/null ) || \
       [[ -f .rubocop.yml ]] || \
       ( [[ -f CLAUDE.md ]] && grep -qiE 'lint command|eslint|golangci|ruff|pylint|rubocop|credo' CLAUDE.md 2>/dev/null ); then
        details+="Lint ✓"
        ((score++))
    else
        details+="Lint ✗"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "Quality Gates" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ $score -lt $max ]]; then
        ASSESS_RECOMMENDATIONS+=("Add missing quality gates              document test and lint commands")
    fi
}

assess_skills_library() {
    local repo_root="$1"
    local installed=0
    local available=0

    # Count available skills from agilar-coder repo
    for skill_file in "$repo_root"/implementations/claude-code/*.md; do
        [[ -f "$skill_file" ]] || continue
        ((available++))
    done

    # Count installed skills
    if [[ -d .claude/skills ]]; then
        for skill_file in .claude/skills/*.md; do
            [[ -f "$skill_file" ]] || continue
            ((installed++))
        done
    fi

    local pct=0
    if [[ $available -gt 0 ]]; then
        pct=$(( installed * 100 / available ))
    fi

    print_dimension "Skills Library" "$pct" "$installed of $available skills"

    # For scoring: use the ratio as a proportion of 10 points
    # This gives skills appropriate weight in the overall score
    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + installed ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + available ))

    local missing=$(( available - installed ))
    if [[ $missing -gt 0 ]]; then
        ASSESS_RECOMMENDATIONS+=("Install $missing missing skills               agilar-coder install")
    fi
}

assess_documentation() {
    local score=0
    local max=2
    local details=""

    # Project documentation (README or CLAUDE.md — either counts)
    if [[ -f README.md || -f readme.md || -f README || -f CLAUDE.md ]]; then
        if [[ -f README.md || -f readme.md || -f README ]]; then
            details+="README ✓  "
        else
            details+="CLAUDE.md ✓  "
        fi
        ((score++))
    else
        details+="README ✗  "
    fi

    # Stack reference (docs, CLAUDE.md tech stack section, or TOOLCHAIN.md)
    if [[ -f TOOLCHAIN.md ]] || \
       [[ -f docs/stack-reference.md || -f docs/STACK.md ]] || \
       ( [[ -f CLAUDE.md ]] && grep -qiE 'tech.stack|toolchain|stack' CLAUDE.md 2>/dev/null ); then
        details+="Stack ref ✓"
        ((score++))
    else
        details+="Stack ref ✗"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "Documentation" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ ! -f TOOLCHAIN.md && ! -f docs/stack-reference.md ]]; then
        if [[ ! -f CLAUDE.md ]] || ! grep -qiE 'tech.stack|toolchain|stack' CLAUDE.md 2>/dev/null; then
            ASSESS_RECOMMENDATIONS+=("Add stack reference                    TOOLCHAIN.md or tech stack section in CLAUDE.md")
        fi
    fi
}

assess_ci_pipeline() {
    local score=0
    local max=1
    local details=""

    if compgen -G ".github/workflows/*.yml" > /dev/null 2>&1 || \
       compgen -G ".github/workflows/*.yaml" > /dev/null 2>&1; then
        details="GitHub Actions ✓"
        score=1
    elif [[ -f .gitlab-ci.yml ]]; then
        details="GitLab CI ✓"
        score=1
    elif [[ -f Jenkinsfile ]]; then
        details="Jenkins ✓"
        score=1
    elif [[ -d .circleci ]]; then
        details="CircleCI ✓"
        score=1
    elif [[ -f bitbucket-pipelines.yml ]]; then
        details="Bitbucket Pipelines ✓"
        score=1
    else
        details="No CI/CD pipeline found"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "CI/CD Pipeline" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ $score -eq 0 ]]; then
        ASSESS_RECOMMENDATIONS+=("Set up CI/CD pipeline                 .github/workflows/, .gitlab-ci.yml, or equivalent")
    fi
}

assess_backlog() {
    local score=0
    local max=1
    local details=""

    if [[ -d backlog ]] || \
       [[ -f backlog.yaml || -f backlog.yml || -f backlog.md || -f BACKLOG.md ]] || \
       [[ -d .jira ]] || \
       [[ -d .github/ISSUE_TEMPLATE ]]; then
        score=1
        if [[ -d backlog ]]; then details="backlog/ ✓"
        elif [[ -f backlog.yaml || -f backlog.yml ]]; then details="backlog.yaml ✓"
        elif [[ -f backlog.md || -f BACKLOG.md ]]; then details="backlog.md ✓"
        elif [[ -d .github/ISSUE_TEMPLATE ]]; then details="GitHub Issues ✓"
        else details="Jira config ✓"
        fi
    else
        details="No backlog structure found"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "Backlog" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ $score -eq 0 ]]; then
        ASSESS_RECOMMENDATIONS+=("Set up backlog structure               agilar-coder install (creates backlog/)")
    fi
}

assess_framework_tracking() {
    local repo_root="$1"
    local score=0
    local max=2
    local details=""

    if [[ -f .agilar-coder.version ]]; then
        local installed_version
        installed_version="$(cat .agilar-coder.version)"
        local current_version
        current_version="$(cat "$repo_root/VERSION" 2>/dev/null || echo "unknown")"
        details+=".agilar-coder.version ✓"
        ((score++))
        if [[ "$installed_version" == "$current_version" ]]; then
            details+=" (current)"
            ((score++))
        else
            details+=" (outdated: $installed_version → $current_version)"
        fi
    else
        details="Not tracked by agilar-coder"
    fi

    local pct=$(( score * 100 / max ))
    print_dimension "Framework Tracking" "$pct" "$details"

    ASSESS_TOTAL_SCORE=$(( ASSESS_TOTAL_SCORE + score ))
    ASSESS_TOTAL_MAX=$(( ASSESS_TOTAL_MAX + max ))

    if [[ ! -f .agilar-coder.version ]]; then
        ASSESS_RECOMMENDATIONS+=("Track with agilar-coder               agilar-coder install (creates .agilar-coder.version)")
    elif [[ $score -eq 1 ]]; then
        ASSESS_RECOMMENDATIONS+=("Upgrade agilar-coder                  agilar-coder upgrade")
    fi
}

# ─────────────────────────────────────────────────────────────────────────────
# Subcommands
# ─────────────────────────────────────────────────────────────────────────────

fill_gaps() {
    local repo_root="$1"

    echo ""
    echo "Filling methodology gaps..."
    echo ""

    # Skills: install only missing ones
    local added=0
    mkdir -p .claude/skills
    for skill_file in "$repo_root"/implementations/claude-code/*.md; do
        [[ -f "$skill_file" ]] || continue
        local skill_name
        skill_name="$(basename "$skill_file")"
        if [[ ! -f ".claude/skills/$skill_name" ]]; then
            cp "$skill_file" ".claude/skills/$skill_name"
            echo "  Added skill: $skill_name"
            ((added++))
        fi
    done
    [[ $added -eq 0 ]] && echo "  Skills: all present"

    # AGENTS.md / GEMINI.md symlinks if missing
    if [[ -f CLAUDE.md && ! -f AGENTS.md && ! -L AGENTS.md ]]; then
        ln -s CLAUDE.md AGENTS.md
        echo "  Created: AGENTS.md → CLAUDE.md"
    fi
    if [[ -f CLAUDE.md && ! -f GEMINI.md && ! -L GEMINI.md ]]; then
        ln -s CLAUDE.md GEMINI.md
        echo "  Created: GEMINI.md → CLAUDE.md"
    fi

    # Backlog structure if missing
    if [[ ! -d backlog ]] && \
       [[ ! -f backlog.yaml && ! -f backlog.yml && ! -f backlog.md && ! -f BACKLOG.md ]] && \
       [[ ! -d .github/ISSUE_TEMPLATE ]]; then
        mkdir -p backlog/ready backlog/in_progress backlog/done
        touch backlog/ready/.gitkeep backlog/in_progress/.gitkeep backlog/done/.gitkeep
        echo "  Created: backlog/ directory structure"
    fi

    # Canonical skill docs if docs/skills/ doesn't exist
    if [[ ! -d docs/skills ]]; then
        mkdir -p docs/skills
        local docs_added=0
        for skill_dir in "$repo_root"/skills/*/; do
            [[ -d "$skill_dir" ]] || continue
            local sname
            sname="$(basename "$skill_dir")"
            if [[ -f "$skill_dir/SKILL.md" ]]; then
                cp "$skill_dir/SKILL.md" "docs/skills/$sname.md"
                ((docs_added++))
            fi
        done
        if [[ $docs_added -gt 0 ]]; then
            echo "  Created: docs/skills/ ($docs_added canonical references)"
        fi
    fi

    # Version tracking
    echo "$VERSION" > .agilar-coder.version
    echo "  Created: .agilar-coder.version ($VERSION)"

    echo ""
    echo "Done. Run 'agilar-coder assess' to see updated compliance."
}

has_methodology_signals() {
    # Returns 0 (true) if the project has any methodology artifacts
    [[ -f CLAUDE.md ]] && return 0
    [[ -f AGENTS.md || -L AGENTS.md ]] && return 0
    [[ -d .claude/skills ]] && return 0
    compgen -G ".github/workflows/*.yml" > /dev/null 2>&1 && return 0
    compgen -G ".github/workflows/*.yaml" > /dev/null 2>&1 && return 0
    [[ -f Makefile ]] && return 0
    [[ -d docs ]] && return 0
    [[ -f DEVOPS.md ]] && return 0
    [[ -d backlog ]] && return 0
    [[ -f .cursorrules ]] && return 0
    return 1
}

cmd_install() {
    local repo_root="$1"

    # Verify scaffold exists
    if [[ ! -x "$repo_root/scaffold" ]]; then
        echo "Error: scaffold not found at $repo_root/scaffold"
        exit 1
    fi

    echo "agilar-coder v$VERSION — Project Setup"
    echo ""

    # Smart install: detect existing methodology
    if has_methodology_signals; then
        # Consulting mode: assess first, then offer choices
        cmd_assess "$repo_root"
        echo ""
        echo "This project already has methodology artifacts."
        echo "  [1] Fill gaps only (add what's missing, don't touch what exists)"
        echo "  [2] Full install (scaffold wizard — may overwrite existing files)"
        echo "  [3] Abort"
        echo ""
        read -rp "Choice [1/2/3]: " choice
        case "$choice" in
            1)
                fill_gaps "$repo_root"
                ;;
            2)
                echo ""
                run_full_scaffold "$repo_root"
                ;;
            3|*)
                echo "Aborted."
                exit 0
                ;;
        esac
    else
        # Greenfield: run scaffold wizard directly
        run_full_scaffold "$repo_root"
    fi
}

run_full_scaffold() {
    local repo_root="$1"

    # Check for existing skills with different content
    if [[ -d .claude/skills ]]; then
        local conflicts=()
        for skill_file in "$repo_root"/implementations/claude-code/*.md; do
            [[ -f "$skill_file" ]] || continue
            local skill_name
            skill_name="$(basename "$skill_file")"
            if [[ -f ".claude/skills/$skill_name" ]] && ! diff -q "$skill_file" ".claude/skills/$skill_name" > /dev/null 2>&1; then
                conflicts+=("$skill_name")
            fi
        done

        if [[ ${#conflicts[@]} -gt 0 ]]; then
            echo "Existing skills with different content detected:"
            for c in "${conflicts[@]}"; do
                echo ""
                echo "  ── $c ──"
                diff -u ".claude/skills/$c" "$repo_root/implementations/claude-code/$c" --label "installed/$c" --label "agilar-coder/$c" || true
            done
            echo ""
            read -rp "Scaffold will overwrite these ${#conflicts[@]} skill(s). Continue? [Y/n] " answer
            if [[ "$answer" =~ ^[Nn] ]]; then
                echo "Aborted."
                exit 0
            fi
            echo ""
        fi
    fi

    # Run scaffold (it handles all the interactive prompts)
    "$repo_root/scaffold"

    # Write version file to track what was installed
    echo "$VERSION" > .agilar-coder.version
    echo ""
    echo "Version $VERSION recorded in .agilar-coder.version"
}

cmd_status() {
    local repo_root="$1"
    local available_version
    available_version="$(cat "$repo_root/VERSION" 2>/dev/null || echo "unknown")"

    # Count skills
    local installed_count=0
    local available_count=0
    local modified_count=0

    for skill_file in "$repo_root"/implementations/claude-code/*.md; do
        [[ -f "$skill_file" ]] || continue
        ((available_count++))
        local skill_name
        skill_name="$(basename "$skill_file")"
        if [[ -f ".claude/skills/$skill_name" ]]; then
            if ! diff -q "$skill_file" ".claude/skills/$skill_name" > /dev/null 2>&1; then
                ((modified_count++))
            fi
        fi
    done

    if [[ -d .claude/skills ]]; then
        for skill_file in .claude/skills/*.md; do
            [[ -f "$skill_file" ]] || continue
            ((installed_count++))
        done
    fi

    echo "agilar-coder status"
    echo "═══════════════════"

    if [[ -f .agilar-coder.version ]]; then
        local installed_version
        installed_version="$(cat .agilar-coder.version)"
        echo -e "  Installed: ${GREEN}$installed_version${NC}"
        echo "  Available: $available_version"
        if [[ "$installed_version" == "$available_version" ]]; then
            echo -e "  Status:    ${GREEN}up to date${NC}"
        else
            echo -e "  Status:    ${RED}upgrade available${NC}"
        fi
    else
        echo -e "  ${RED}agilar-coder is not installed, or not correctly installed, in this repository${NC}"
        echo "  Tip: run 'agilar-coder install' to set up, or 'agilar-coder upgrade' if skills already exist"
        echo "  Latest version available: $available_version"
    fi

    echo ""

    # Skills — single line, color-coded
    local skills_color
    if [[ $installed_count -eq $available_count ]]; then
        skills_color="$GREEN"
    elif [[ $installed_count -eq 0 ]]; then
        skills_color="$RED"
    else
        skills_color="$YELLOW"
    fi
    local skills_line="Skills: ${skills_color}$installed_count of $available_count available${NC}"
    if [[ $modified_count -gt 0 ]]; then
        skills_line="$skills_line, ${RED}$modified_count skill(s) need to be upgraded${NC}"
    fi
    echo -e "  $skills_line"
}

cmd_upgrade() {
    local repo_root="$1"
    local available_version
    available_version="$(cat "$repo_root/VERSION" 2>/dev/null || echo "unknown")"

    local installed_version
    if [[ -f .agilar-coder.version ]]; then
        installed_version="$(cat .agilar-coder.version)"
    elif [[ -d .claude/skills ]]; then
        installed_version="unknown"
    else
        echo "Error: No .agilar-coder.version found and no skills installed."
        echo "  Run 'agilar-coder install' first."
        exit 1
    fi

    echo "agilar-coder upgrade"
    echo "═══════════════════"
    echo "  From: $installed_version"
    echo "  To:   $available_version"
    echo ""

    if [[ "$installed_version" == "$available_version" ]]; then
        echo "Already at latest version. Upgrading skills anyway..."
        echo ""
    fi

    # 1. Update skills (implementations/claude-code/ → .claude/skills/)
    local updated=0
    local skipped=0
    local added=0
    if [[ -d .claude/skills ]]; then
        for skill_file in "$repo_root"/implementations/claude-code/*.md; do
            [[ -f "$skill_file" ]] || continue
            local skill_name
            skill_name="$(basename "$skill_file")"
            if [[ -f ".claude/skills/$skill_name" ]]; then
                if ! diff -q "$skill_file" ".claude/skills/$skill_name" > /dev/null 2>&1; then
                    echo ""
                    echo "  ── $skill_name ──"
                    diff -u ".claude/skills/$skill_name" "$skill_file" --label "installed/$skill_name" --label "agilar-coder/$skill_name" || true
                    echo ""
                    read -rp "  Apply this update? [Y/n] " answer
                    if [[ ! "$answer" =~ ^[Nn] ]]; then
                        cp "$skill_file" ".claude/skills/$skill_name"
                        ((updated++))
                        echo "  Updated: $skill_name"
                    else
                        ((skipped++))
                        echo "  Skipped: $skill_name"
                    fi
                fi
            else
                cp "$skill_file" ".claude/skills/$skill_name"
                ((added++))
                echo "  Added:   $skill_name"
            fi
        done
    else
        mkdir -p .claude/skills
        cp "$repo_root"/implementations/claude-code/*.md .claude/skills/
        added=$(find "$repo_root/implementations/claude-code" -name '*.md' -maxdepth 1 2>/dev/null | wc -l | tr -d ' ')
        echo "  Created .claude/skills/ with $added skills"
    fi

    # 2. Detect removed skills
    local removed=()
    if [[ -d .claude/skills ]]; then
        for skill_file in .claude/skills/*.md; do
            [[ -f "$skill_file" ]] || continue
            local skill_name
            skill_name="$(basename "$skill_file")"
            if [[ ! -f "$repo_root/implementations/claude-code/$skill_name" ]]; then
                removed+=("$skill_name")
            fi
        done
    fi

    if [[ ${#removed[@]} -gt 0 ]]; then
        echo ""
        echo "  Skills no longer in agilar-coder:"
        for r in "${removed[@]}"; do
            echo "    - $r"
        done
        read -rp "  Remove them? [y/N] " answer
        if [[ "$answer" =~ ^[Yy] ]]; then
            for r in "${removed[@]}"; do
                rm ".claude/skills/$r"
                echo "  Removed: .claude/skills/$r"
            done
        fi
    fi

    # 3. Update docs/skills/ (canonical copies)
    if [[ -d docs/skills ]]; then
        for skill_dir in "$repo_root"/skills/*/; do
            [[ -d "$skill_dir" ]] || continue
            local skill_name
            skill_name="$(basename "$skill_dir")"
            if [[ -f "$skill_dir/SKILL.md" ]]; then
                cp "$skill_dir/SKILL.md" "docs/skills/$skill_name.md"
            fi
        done
        echo "  Updated docs/skills/ (canonical references)"
    fi

    # 4. CLAUDE.md diff — show what's new in the template
    echo ""
    if [[ -f CLAUDE.md && -f "$repo_root/templates/CLAUDE.md.tmpl" ]]; then
        echo "CLAUDE.md template changes:"
        echo "  The CLAUDE.md template in agilar-coder may have new sections."
        echo "  Your project's CLAUDE.md is customized and won't be overwritten."
        echo "  Review the template at: $repo_root/templates/CLAUDE.md.tmpl"
        echo ""
        echo "  Tip: Run 'diff CLAUDE.md <(agilar-coder-scaffold-preview)' to see differences."
    fi

    # 5. Update version file
    echo "$available_version" > .agilar-coder.version

    echo ""
    echo "Summary: $added added, $updated updated, $skipped skipped, ${#removed[@]} removed candidates"
    echo "Version: $installed_version → $available_version"
    echo "Done."
}

cmd_assess() {
    local repo_root="$1"
    local project_name
    project_name="$(basename "$(pwd)")"

    # Try to get project name from package.json
    if [[ -f package.json ]]; then
        local pkg_name
        pkg_name="$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' package.json 2>/dev/null | head -1 | sed 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)"/\1/')"
        [[ -n "$pkg_name" ]] && project_name="$pkg_name"
    fi

    echo "agilar-coder assess"
    echo "═══════════════════"
    echo "Project: $project_name"
    echo ""

    ASSESS_TOTAL_SCORE=0
    ASSESS_TOTAL_MAX=0
    ASSESS_RECOMMENDATIONS=()

    assess_agent_guidance
    assess_working_agreements
    assess_quality_gates
    assess_skills_library "$repo_root"
    assess_documentation
    assess_ci_pipeline
    assess_backlog
    assess_framework_tracking "$repo_root"

    echo ""
    local overall_pct=0
    if [[ $ASSESS_TOTAL_MAX -gt 0 ]]; then
        overall_pct=$(( ASSESS_TOTAL_SCORE * 100 / ASSESS_TOTAL_MAX ))
    fi
    local overall_color
    overall_color="$(score_color "$overall_pct")"
    echo -e "  Overall: ${overall_color}${overall_pct}% Agilar-compliant${NC}"

    if [[ ${#ASSESS_RECOMMENDATIONS[@]} -gt 0 ]]; then
        echo ""
        echo "Recommendations:"
        local i=1
        for rec in "${ASSESS_RECOMMENDATIONS[@]}"; do
            echo "  $i. $rec"
            ((i++))
        done
    fi
}

