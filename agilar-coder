# Detect project settings from project files and existing CLAUDE.md.
# Sets PROJ_* globals used by generate_section_content.
detect_project_settings() {
    [[ -n "${PROJ_SETTINGS_LOADED:-}" ]] && return 0

    # Stack detection
    PROJ_TEST_CMD="" PROJ_LINT_CMD="" PROJ_BUILD_CMD="" PROJ_STACK_LABEL=""
    if [[ -f package.json ]]; then
        PROJ_TEST_CMD="npm test"; PROJ_LINT_CMD="npx eslint . && npx tsc --noEmit"
        PROJ_BUILD_CMD="npm run build"; PROJ_STACK_LABEL="Node.js / TypeScript"
    elif [[ -f go.mod ]]; then
        PROJ_TEST_CMD="go test ./..."; PROJ_LINT_CMD="go vet ./... && golangci-lint run ./..."
        PROJ_BUILD_CMD="go build ./cmd/..."; PROJ_STACK_LABEL="Go"
    elif [[ -f pyproject.toml || -f setup.py || -f requirements.txt ]]; then
        PROJ_TEST_CMD="pytest"; PROJ_LINT_CMD="ruff check . && mypy src/"
        PROJ_BUILD_CMD="python -m build"; PROJ_STACK_LABEL="Python"
    elif [[ -f mix.exs ]]; then
        PROJ_TEST_CMD="mix test"; PROJ_LINT_CMD="mix format --check-formatted && mix credo --strict"
        PROJ_BUILD_CMD="MIX_ENV=prod mix release"; PROJ_STACK_LABEL="Elixir"
    fi

    # Team mode from existing CLAUDE.md
    PROJ_TEAM_MODE="solo" PROJ_CODE_REVIEW="no" PROJ_SIZE_UNIT="working session"
    if [[ -f CLAUDE.md ]]; then
        if grep -q 'Multi-agent' CLAUDE.md 2>/dev/null; then
            PROJ_TEAM_MODE="multi-agent"
        elif grep -q 'Multi-human' CLAUDE.md 2>/dev/null; then
            PROJ_TEAM_MODE="multi-human"
            PROJ_SIZE_UNIT="sprint"
        fi
        if grep -qE 'No merge without code review' CLAUDE.md 2>/dev/null; then
            PROJ_CODE_REVIEW="yes"
        fi
    fi

    PROJ_SETTINGS_LOADED=1
}

