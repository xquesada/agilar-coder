# Check if a section in a file exists but has only blank lines and/or TODO comments.
section_is_empty() {
    local name="$1"
    local file="$2"

    local content
    content="$(awk -v section="$name" '
        /^## / {
            h = $0; sub(/^## /, "", h); gsub(/[[:space:]]+$/, "", h)
            if (h == section) { found = 1; next }
            else if (found) { exit }
        }
        found { print }
    ' "$file" | grep -v '^[[:space:]]*$' | grep -v '<!-- TODO')"

    [[ -z "$content" ]]
}

# Remove a section that has only TODO/empty content (header + blank lines + TODO line).
# The section is deleted so it can be re-appended with real content.
remove_empty_section() {
    local name="$1"
    local file="$2"

    local tmpfile
    tmpfile="$(mktemp)"
    awk -v section="$name" '
        /^## / {
            h = $0; sub(/^## /, "", h); gsub(/[[:space:]]+$/, "", h)
            if (h == section) { removing = 1; next }
            else { removing = 0 }
        }
        removing && /^[[:space:]]*$/ { next }
        removing && /<!-- TODO/ { next }
        removing { removing = 0 }
        { print }
    ' "$file" > "$tmpfile"
    mv "$tmpfile" "$file"
}

# Add or populate a CLAUDE.md section.
# - If keyword_pattern matches in CLAUDE.md -> content exists (possibly under a different header), skip
# - If section header exists but is empty/TODO -> replace with generated content
# - If section header is missing -> append with generated content
# Returns 0 if content was added/replaced, 1 if skipped.
ensure_section() {
    local name="$1"
    local keyword_pattern="$2"

    # Skip if content already exists (detected by keyword, possibly under a different header)
    if [[ -n "$keyword_pattern" ]] && grep -qiE "$keyword_pattern" CLAUDE.md 2>/dev/null; then
        return 1
    fi

    local content
    content="$(generate_section_content "$name")"

    if grep -q "^## $name" CLAUDE.md 2>/dev/null; then
        if section_is_empty "$name" CLAUDE.md; then
            remove_empty_section "$name" CLAUDE.md
            printf '\n## %s\n\n%s\n' "$name" "$content" >> CLAUDE.md
            return 0
        fi
        return 1
    fi

    printf '\n## %s\n\n%s\n' "$name" "$content" >> CLAUDE.md
    return 0
}

