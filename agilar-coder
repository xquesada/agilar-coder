has_methodology_signals() {
    # Returns 0 (true) if the project has any methodology artifacts
    [[ -f CLAUDE.md ]] && return 0
    [[ -f AGENTS.md || -L AGENTS.md ]] && return 0
    [[ -d .claude/skills ]] && return 0
    compgen -G ".github/workflows/*.yml" > /dev/null 2>&1 && return 0
    compgen -G ".github/workflows/*.yaml" > /dev/null 2>&1 && return 0
    [[ -f Makefile ]] && return 0
    [[ -d docs ]] && return 0
    [[ -f DEVOPS.md ]] && return 0
    [[ -d backlog ]] && return 0
    [[ -f .cursorrules ]] && return 0
    return 1
}

cmd_install() {
    local repo_root="$1"

    # Verify scaffold exists
    if [[ ! -x "$repo_root/scaffold" ]]; then
        echo "Error: scaffold not found at $repo_root/scaffold"
        exit 1
    fi

    echo "agilar-coder v$VERSION — Project Setup"
    echo ""

    # Smart install: detect existing methodology
    if has_methodology_signals; then
        # Consulting mode: assess first, then offer choices
        cmd_assess "$repo_root"

        # If already 100%, congratulate and point to config
        local overall_pct=0
        if [[ $ASSESS_TOTAL_MAX -gt 0 ]]; then
            overall_pct=$(( ASSESS_TOTAL_SCORE * 100 / ASSESS_TOTAL_MAX ))
        fi
        if [[ $overall_pct -eq 100 ]]; then
            # Still run fill_gaps — assess checks structure, not CLAUDE.md content completeness
            fill_gaps "$repo_root"
            register_claude_hook
            echo ""
            echo "This project is fully Agilar-compliant."
            echo "Run 'agilar-coder config$(if [[ "${2:-.}" != "." ]]; then echo " ${2:-.}"; fi)' to reconfigure parameters."
            exit 0
        fi

        echo ""
        echo "This project already has methodology artifacts."
        echo "  [1] Fill gaps only (add what's missing, don't touch what exists)"
        echo "  [2] Reconfigure (scaffold wizard — may overwrite existing files)"
        echo "  [3] Abort"
        echo ""
        read -rp "Choice [1/2/3]: " choice
        case "$choice" in
            1)
                fill_gaps "$repo_root"
                ;;
            2)
                echo ""
                run_full_scaffold "$repo_root"
                ;;
            3|*)
                echo "Aborted."
                exit 0
                ;;
        esac
    else
        # Greenfield: run scaffold wizard directly
        run_full_scaffold "$repo_root"
    fi
}

cmd_config() {
    local repo_root="$1"

    # Verify scaffold exists
    if [[ ! -x "$repo_root/scaffold" ]]; then
        echo "Error: scaffold not found at $repo_root/scaffold"
        exit 1
    fi

    echo "agilar-coder v$VERSION — Reconfigure"
    echo ""

    run_full_scaffold "$repo_root"
}

run_full_scaffold() {
    local repo_root="$1"

    # Check for existing skills with different content (all detected tools)
    detect_tools_from_project
    local total_conflicts=0
    for tool in $DETECTED_TOOLS; do
        local impl_dir="$repo_root/implementations/$tool"
        [[ -d "$impl_dir" ]] || continue
        local target_dir
        target_dir="$(tool_skill_target "$tool")"
        [[ -d "$target_dir" ]] || continue

        local conflicts=()
        for skill_file in "$impl_dir"/*.md; do
            [[ -f "$skill_file" ]] || continue
            local skill_name
            skill_name="$(basename "$skill_file" .md)"
            local installed_path
            installed_path="$(installed_skill_path "$tool" "$skill_name" "$target_dir")"
            if [[ -f "$installed_path" ]] && ! diff -q "$skill_file" "$installed_path" > /dev/null 2>&1; then
                conflicts+=("$skill_name")
            fi
        done

        if [[ ${#conflicts[@]} -gt 0 ]]; then
            echo "Existing $tool skills with different content detected:"
            for c in "${conflicts[@]}"; do
                local installed_path
                installed_path="$(installed_skill_path "$tool" "$c" "$target_dir")"
                echo ""
                echo "  ── $c ($tool) ──"
                diff -u "$installed_path" "$impl_dir/$c.md" --label "installed/$c" --label "agilar-coder/$c" || true
            done
            ((total_conflicts += ${#conflicts[@]}))
        fi
    done

    if [[ $total_conflicts -gt 0 ]]; then
        echo ""
        read -rp "Scaffold will overwrite these $total_conflicts skill(s). Continue? [Y/n] " answer
        if [[ "$answer" =~ ^[Nn] ]]; then
            echo "Aborted."
            exit 0
        fi
        echo ""
    fi

    # Run scaffold (it handles all the interactive prompts)
    "$repo_root/scaffold"

    # Write version file to track what was installed
    echo "$VERSION" > .agilar-coder.version
    echo ""
    echo "Version $VERSION recorded in .agilar-coder.version"

    # Claude Code startup hook
    register_claude_hook
}

cmd_status() {
    local repo_root="$1"
    local available_version
    available_version="$(tr -d '\r' < "$repo_root/VERSION" 2>/dev/null || echo "unknown")"

    echo "agilar-coder status"
    echo "═══════════════════"

    if [[ -f .agilar-coder.version ]]; then
        local installed_version
        installed_version="$(tr -d '\r' < .agilar-coder.version)"
        echo -e "  Installed: ${GREEN}$installed_version${NC}"
        echo "  Available: $available_version"
        if [[ "$installed_version" == "$available_version" ]]; then
            echo -e "  Status:    ${GREEN}up to date${NC}"
        else
            echo -e "  Status:    ${RED}upgrade available${NC}"
        fi
    else
        echo -e "  ${RED}agilar-coder is not installed, or not correctly installed, in this repository${NC}"
        echo "  Tip: run 'agilar-coder install' to set up, or 'agilar-coder upgrade' if skills already exist"
        echo "  Latest version available: $available_version"
    fi

    echo ""

    # Skills per tool
    detect_tools_from_project
    for tool in $DETECTED_TOOLS; do
        local impl_dir="$repo_root/implementations/$tool"
        [[ -d "$impl_dir" ]] || continue

        local target_dir
        target_dir="$(tool_skill_target "$tool")"

        local installed_count=0
        local available_count=0
        local modified_count=0

        for skill_file in "$impl_dir"/*.md; do
            [[ -f "$skill_file" ]] || continue
            ((available_count++))
            local skill_name
            skill_name="$(basename "$skill_file" .md)"
            local installed_path
            installed_path="$(installed_skill_path "$tool" "$skill_name" "$target_dir")"
            if [[ -f "$installed_path" ]]; then
                if ! diff -q "$skill_file" "$installed_path" > /dev/null 2>&1; then
                    ((modified_count++))
                fi
            fi
        done

        # Count installed skills
        case "$tool" in
            claude-code)
                if [[ -d "$target_dir" ]]; then
                    for sf in "$target_dir"/*.md; do
                        [[ -f "$sf" ]] || continue
                        ((installed_count++))
                    done
                fi
                ;;
            codex)
                if [[ -d "$target_dir" ]]; then
                    for sd in "$target_dir"/*/; do
                        [[ -f "$sd/SKILL.md" ]] || continue
                        ((installed_count++))
                    done
                fi
                ;;
        esac

        local skills_color
        if [[ $installed_count -eq $available_count ]]; then
            skills_color="$GREEN"
        elif [[ $installed_count -eq 0 ]]; then
            skills_color="$RED"
        else
            skills_color="$YELLOW"
        fi
        local skills_line="Skills ($tool): ${skills_color}$installed_count of $available_count available${NC}"
        if [[ $modified_count -gt 0 ]]; then
            skills_line="$skills_line, ${RED}$modified_count skill(s) need to be upgraded${NC}"
        fi
        echo -e "  $skills_line"
    done

    if [[ -z "$DETECTED_TOOLS" ]]; then
        echo -e "  ${YELLOW}No AI coding tools detected (claude, codex)${NC}"
    fi
}

check_pending_migrations() {
    local pending=()

    # 1.3.0: docs/decisions/ should be docs/architecture/
    if [[ -d docs/decisions ]]; then
        pending+=("Rename docs/decisions/ to docs/architecture/ (ADRs location changed in 1.3.0)")
    fi

    # 1.3.0: docs/plans/ files should move into PBI files as ## Design sections
    if [[ -d docs/plans ]] && find docs/plans -name '*.md' -maxdepth 1 2>/dev/null | grep -q .; then
        pending+=("Move designs from docs/plans/ into their PBI files under a ## Design section (design-in-PBI change from 1.3.0)")
    fi

    if [[ ${#pending[@]} -gt 0 ]]; then
        echo ""
        echo "Pending manual actions:"
        echo "────────────────────────────────────────"
        local i=1
        for p in "${pending[@]}"; do
            echo "  $i. $p"
            ((i++))
        done
    fi
}

show_changelog_diff() {
    local changelog="$1"
    local from_version="$2"
    local to_version="$3"

    echo ""
    echo "What's new ($from_version → $to_version):"
    echo "────────────────────────────────────────"

    local in_range=false

    while IFS= read -r line; do
        if [[ "$line" =~ ^##\ \[([0-9]+\.[0-9]+\.[0-9]+)\] ]]; then
            local ver="${BASH_REMATCH[1]}"
            if [[ "$ver" == "$from_version" ]]; then
                in_range=false
                continue
            fi
            if [[ "$in_range" != true && "$ver" == "$to_version" ]]; then
                in_range=true
            fi
        fi

        if [[ "$in_range" == true ]]; then
            echo "  $line"
        fi
    done < "$changelog"

    echo ""
}

cmd_upgrade() {
    local repo_root="$1"
    local available_version
    available_version="$(tr -d '\r' < "$repo_root/VERSION" 2>/dev/null || echo "unknown")"

    local installed_version
    if [[ -f .agilar-coder.version ]]; then
        installed_version="$(tr -d '\r' < .agilar-coder.version)"
    elif [[ -d .claude/skills ]] || [[ -d "${CODEX_HOME:-$HOME/.codex}/skills" ]]; then
        installed_version="unknown"
    else
        echo "Error: No .agilar-coder.version found and no skills installed."
        echo "  Run 'agilar-coder install' first."
        exit 1
    fi

    echo "agilar-coder upgrade"
    echo "═══════════════════"
    echo "  From: $installed_version"
    echo "  To:   $available_version"
    echo ""

    if [[ "$installed_version" == "$available_version" ]]; then
        echo "Already at latest version. Upgrading skills anyway..."
        echo ""
    fi

    # 1. Update skills for all detected tools
    detect_tools_from_project
    local total_updated=0
    local total_skipped=0
    local total_added=0
    local total_removed_candidates=0

    for tool in $DETECTED_TOOLS; do
        local impl_dir="$repo_root/implementations/$tool"
        [[ -d "$impl_dir" ]] || continue

        local target_dir
        target_dir="$(tool_skill_target "$tool")"

        echo "  ── $tool ──"

        local updated=0
        local skipped=0
        local added=0
        local changed_skills=()

        if [[ -d "$target_dir" ]]; then
            # Collect new and changed skills
            for skill_file in "$impl_dir"/*.md; do
                [[ -f "$skill_file" ]] || continue
                local skill_name
                skill_name="$(basename "$skill_file" .md)"
                local installed_path
                installed_path="$(installed_skill_path "$tool" "$skill_name" "$target_dir")"
                if [[ -f "$installed_path" ]]; then
                    if ! diff -q "$skill_file" "$installed_path" > /dev/null 2>&1; then
                        changed_skills+=("$skill_name")
                    fi
                else
                    install_skill_for_tool "$tool" "$skill_file" "$target_dir"
                    ((added++))
                    echo "    Added: $skill_name"
                fi
            done

            # Prompt once for all changed skills
            if [[ ${#changed_skills[@]} -gt 0 ]]; then
                echo "    Skills with updates:"
                for s in "${changed_skills[@]}"; do
                    echo "      - $s"
                done
                echo ""
                read -rp "    Apply all $tool skill updates? [Y/n] " answer
                if [[ ! "$answer" =~ ^[Nn] ]]; then
                    for s in "${changed_skills[@]}"; do
                        install_skill_for_tool "$tool" "$impl_dir/$s.md" "$target_dir"
                        ((updated++))
                    done
                    echo "    Updated $updated skill(s)"
                else
                    skipped=${#changed_skills[@]}
                    echo "    Skipped $skipped skill(s)"
                fi
            fi
        else
            mkdir -p "$target_dir"
            for skill_file in "$impl_dir"/*.md; do
                [[ -f "$skill_file" ]] || continue
                install_skill_for_tool "$tool" "$skill_file" "$target_dir"
                ((added++))
            done
            echo "    Created $target_dir with $added skills"
        fi

        # Detect removed skills
        local removed=()
        case "$tool" in
            claude-code)
                for skill_file in "$target_dir"/*.md; do
                    [[ -f "$skill_file" ]] || continue
                    local sname
                    sname="$(basename "$skill_file" .md)"
                    if [[ ! -f "$impl_dir/$sname.md" ]]; then
                        removed+=("$sname")
                    fi
                done
                ;;
            codex)
                for skill_dir_entry in "$target_dir"/*/; do
                    [[ -f "$skill_dir_entry/SKILL.md" ]] || continue
                    local sname
                    sname="$(basename "$skill_dir_entry")"
                    # Skip system skills
                    [[ "$sname" == .* ]] && continue
                    if [[ ! -f "$impl_dir/$sname.md" ]]; then
                        removed+=("$sname")
                    fi
                done
                ;;
        esac

        if [[ ${#removed[@]} -gt 0 ]]; then
            echo ""
            echo "    Skills no longer in agilar-coder:"
            for r in "${removed[@]}"; do
                echo "      - $r"
            done
            read -rp "    Remove them? [y/N] " answer
            if [[ "$answer" =~ ^[Yy] ]]; then
                for r in "${removed[@]}"; do
                    case "$tool" in
                        claude-code) rm "$target_dir/$r.md" ;;
                        codex)       rm -rf "${target_dir:?}/${r:?}" ;;
                    esac
                    echo "    Removed: $r"
                done
            fi
        fi

        ((total_updated += updated)) || true
        ((total_skipped += skipped)) || true
        ((total_added += added)) || true
        ((total_removed_candidates += ${#removed[@]})) || true
    done

    # 3. Update docs/skills/ (canonical copies)
    if [[ -d docs/skills ]]; then
        for skill_dir in "$repo_root"/skills/*/; do
            [[ -d "$skill_dir" ]] || continue
            local skill_name
            skill_name="$(basename "$skill_dir")"
            if [[ -f "$skill_dir/SKILL.md" ]]; then
                cp "$skill_dir/SKILL.md" "docs/skills/$skill_name.md"
            fi
        done
        echo "  Updated docs/skills/ (canonical references)"
    fi

    # 4. CLAUDE.md — detect missing and empty sections, offer to populate with real content
    if [[ -f CLAUDE.md && -f "$repo_root/templates/CLAUDE.md.tmpl" ]]; then
        detect_project_settings
        local actionable_sections=()

        # Check template sections: missing or present-but-empty (TODO stubs)
        while IFS= read -r line; do
            local section
            section="$(echo "$line" | tr -d '\r' | sed 's/{{[^}]*}}//g' | sed 's/^## //' | xargs)"
            [[ -z "$section" ]] && continue
            # Skip sections whose generated content is still a TODO stub
            local generated
            generated="$(generate_section_content "$section")"
            local real_content
            real_content="$(echo "$generated" | grep -v '^[[:space:]]*$' | grep -v '<!-- TODO' || true)"
            [[ -z "$real_content" ]] && continue
            if ! grep -q "^## .*${section}" CLAUDE.md 2>/dev/null; then
                actionable_sections+=("$section|missing")
            elif section_is_empty "$section" CLAUDE.md; then
                actionable_sections+=("$section|empty")
            fi
        done < <(grep '^## ' "$repo_root/templates/CLAUDE.md.tmpl")

        if [[ ${#actionable_sections[@]} -gt 0 ]]; then
            echo ""
            echo "CLAUDE.md — ${#actionable_sections[@]} section(s) to update:"
            for entry in "${actionable_sections[@]}"; do
                local s="${entry%%|*}"
                local status="${entry##*|}"
                local desc
                desc="$(describe_section "$s")"
                if [[ "$status" == "empty" ]]; then
                    echo "  - $s (exists but empty) — $desc"
                else
                    echo "  - $s — $desc"
                fi
            done

            echo ""
            echo "  [1] Add all with real content (recommended)"
            echo "  [2] Choose individually"
            echo "  [3] Skip CLAUDE.md updates"
            read -rp "  Choice [1]: " section_choice
            section_choice="${section_choice:-1}"

            case "$section_choice" in
                1)
                    for entry in "${actionable_sections[@]}"; do
                        local s="${entry%%|*}"
                        local status="${entry##*|}"
                        local content
                        content="$(generate_section_content "$s")"
                        if [[ "$status" == "empty" ]]; then
                            remove_empty_section "$s" CLAUDE.md
                        fi
                        printf '\n## %s\n\n%s\n' "$s" "$content" >> CLAUDE.md
                        echo "    Added: $s"
                    done
                    ;;
                2)
                    for entry in "${actionable_sections[@]}"; do
                        local s="${entry%%|*}"
                        local status="${entry##*|}"
                        local content
                        content="$(generate_section_content "$s")"

                        echo ""
                        echo "  ── $s ──"
                        echo "$content" | head -3 | sed 's/^/  /'
                        if [[ $(echo "$content" | wc -l) -gt 3 ]]; then
                            echo "  ..."
                        fi
                        read -rp "    Add to CLAUDE.md? [Y/n] " answer
                        if [[ ! "$answer" =~ ^[Nn] ]]; then
                            if [[ "$status" == "empty" ]]; then
                                remove_empty_section "$s" CLAUDE.md
                            fi
                            printf '\n## %s\n\n%s\n' "$s" "$content" >> CLAUDE.md
                            echo "    Added: $s"
                        fi
                    done
                    ;;
                3|*)
                    echo "  Skipped CLAUDE.md updates."
                    ;;
            esac
        fi
    fi

    # 5. Show what changed (CHANGELOG diff between versions)
    if [[ -f "$repo_root/CHANGELOG.md" && "$installed_version" != "$available_version" ]]; then
        show_changelog_diff "$repo_root/CHANGELOG.md" "$installed_version" "$available_version"
    fi

    # 6. Check for pending migration actions
    check_pending_migrations

    # 7. Update version file
    echo "$available_version" > .agilar-coder.version

    echo ""
    echo "Summary: $total_added added, $total_updated updated, $total_skipped skipped, $total_removed_candidates removed candidates"
    echo "Version: $installed_version → $available_version"
    echo "Done."
}

cmd_assess() {
    local repo_root="$1"
    local project_name
    project_name="$(basename "$(pwd)")"

    # Try to get project name from package.json
    if [[ -f package.json ]]; then
        local pkg_name
        pkg_name="$(grep -o '"name"[[:space:]]*:[[:space:]]*"[^"]*"' package.json 2>/dev/null | head -1 | sed 's/.*"name"[[:space:]]*:[[:space:]]*"\([^"]*\)"/\1/')"
        [[ -n "$pkg_name" ]] && project_name="$pkg_name"
    fi

    echo "agilar-coder assess"
    echo "═══════════════════"
    echo "Project: $project_name"
    echo ""

    ASSESS_TOTAL_SCORE=0
    ASSESS_TOTAL_MAX=0
    ASSESS_RECOMMENDATIONS=()

    assess_agent_guidance
    assess_working_agreements
    assess_quality_gates
    assess_skills_library "$repo_root"
    assess_documentation
    assess_ci_pipeline
    assess_backlog
    assess_framework_tracking "$repo_root"

    echo ""
    local overall_pct=0
    if [[ $ASSESS_TOTAL_MAX -gt 0 ]]; then
        overall_pct=$(( ASSESS_TOTAL_SCORE * 100 / ASSESS_TOTAL_MAX ))
    fi
    local overall_color
    overall_color="$(score_color "$overall_pct")"
    echo -e "  Overall: ${overall_color}${overall_pct}% Agilar-compliant${NC}"

    if [[ ${#ASSESS_RECOMMENDATIONS[@]} -gt 0 ]]; then
        echo ""
        echo "Recommendations:"
        local i=1
        for rec in "${ASSESS_RECOMMENDATIONS[@]}"; do
            echo "  $i. $rec"
            ((i++))
        done
    fi
}

