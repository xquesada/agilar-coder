#!/usr/bin/env bash
set -euo pipefail

# Agilar AI SDLC — Project Scaffold Wizard
# Sets up a new project with the methodology's skills, templates, and configuration.
# Auto-detects existing project setup and confirms rather than asking from scratch.

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"

# Colors
BOLD='\033[1m'
DIM='\033[2m'
GREEN='\033[0;32m'
CYAN='\033[0;36m'
YELLOW='\033[0;33m'
NC='\033[0m'

echo -e "${BOLD}agilar-coder repo scaffold${NC}"
echo -e "${DIM}Sets up your project with the Agilar AI framework - an AI augmented Agile way of working${NC}"
echo ""

# Project directory is the current working directory (passed via agilar-coder install [dir])
PROJECT_DIR="$(pwd)"

# ─────────────────────────────────────────────────────────────────────────────
# Detection phase — scan the project BEFORE asking questions
# ─────────────────────────────────────────────────────────────────────────────

# Detect tech stack
DETECTED_STACK=""
DETECTED_STACK_LABEL=""
if [[ -f "$PROJECT_DIR/package.json" ]]; then
  DETECTED_STACK="1"; DETECTED_STACK_LABEL="Node.js / TypeScript"
elif [[ -f "$PROJECT_DIR/go.mod" ]]; then
  DETECTED_STACK="2"; DETECTED_STACK_LABEL="Go"
elif [[ -f "$PROJECT_DIR/pyproject.toml" || -f "$PROJECT_DIR/setup.py" || -f "$PROJECT_DIR/requirements.txt" ]]; then
  DETECTED_STACK="3"; DETECTED_STACK_LABEL="Python"
elif [[ -f "$PROJECT_DIR/mix.exs" ]]; then
  DETECTED_STACK="4"; DETECTED_STACK_LABEL="Elixir"
fi

# Detect AI coding tool
DETECTED_TOOL=""
DETECTED_TOOL_LABEL=""
if [[ -d "$PROJECT_DIR/.claude" ]]; then
  DETECTED_TOOL="1"; DETECTED_TOOL_LABEL="Claude Code"
elif [[ -d "$PROJECT_DIR/.codex" ]]; then
  DETECTED_TOOL="2"; DETECTED_TOOL_LABEL="Codex CLI"
elif [[ -d "$PROJECT_DIR/.cursor" || -f "$PROJECT_DIR/.cursorrules" ]]; then
  DETECTED_TOOL="3"; DETECTED_TOOL_LABEL="Cursor CLI"
elif [[ -d "$PROJECT_DIR/.gemini" ]]; then
  DETECTED_TOOL="4"; DETECTED_TOOL_LABEL="Google CLI"
elif [[ -d "$PROJECT_DIR/.github/copilot" ]]; then
  DETECTED_TOOL="5"; DETECTED_TOOL_LABEL="GitHub Copilot CLI"
fi

# Detect team mode
DETECTED_TEAM=""
DETECTED_TEAM_LABEL=""
if [[ -d "$PROJECT_DIR/.claude/agents" ]] || [[ -f "$PROJECT_DIR/.claude/agents/code-reviewer.md" ]]; then
  DETECTED_TEAM="2"; DETECTED_TEAM_LABEL="Multi-agent"
elif [[ -f "$PROJECT_DIR/CODEOWNERS" ]] || [[ -d "$PROJECT_DIR/.github/PULL_REQUEST_TEMPLATE" ]] || [[ -f "$PROJECT_DIR/.github/PULL_REQUEST_TEMPLATE.md" ]]; then
  DETECTED_TEAM="3"; DETECTED_TEAM_LABEL="Multi-human"
fi

# Detect CI provider
DETECTED_CI=""
DETECTED_CI_LABEL=""
if compgen -G "$PROJECT_DIR/.github/workflows/*.yml" > /dev/null 2>&1 || \
   compgen -G "$PROJECT_DIR/.github/workflows/*.yaml" > /dev/null 2>&1; then
  DETECTED_CI="1"; DETECTED_CI_LABEL="GitHub Actions"
elif [[ -f "$PROJECT_DIR/.gitlab-ci.yml" ]]; then
  DETECTED_CI="2"; DETECTED_CI_LABEL="GitLab CI"
fi

# Detect backlog system
DETECTED_BACKLOG=""
DETECTED_BACKLOG_LABEL=""
if [[ -d "$PROJECT_DIR/backlog" ]] && [[ ! -f "$PROJECT_DIR/backlog.yaml" ]] && [[ ! -d "$PROJECT_DIR/.jira" ]]; then
  DETECTED_BACKLOG="4"; DETECTED_BACKLOG_LABEL="Filesystem backlog"
elif [[ -f "$PROJECT_DIR/backlog.yaml" || -f "$PROJECT_DIR/backlog.yml" ]]; then
  DETECTED_BACKLOG="4"; DETECTED_BACKLOG_LABEL="Filesystem backlog"
elif [[ -d "$PROJECT_DIR/.jira" ]]; then
  DETECTED_BACKLOG="3"; DETECTED_BACKLOG_LABEL="Jira"
elif [[ -d "$PROJECT_DIR/.github/ISSUE_TEMPLATE" ]]; then
  DETECTED_BACKLOG="4"; DETECTED_BACKLOG_LABEL="Filesystem backlog"
fi

# Detect code review
DETECTED_CODE_REVIEW=""
DETECTED_CODE_REVIEW_LABEL=""
if [[ -f "$PROJECT_DIR/.claude/agents/code-reviewer.md" ]] || \
   [[ -f "$PROJECT_DIR/CODEOWNERS" ]] || \
   [[ -f "$PROJECT_DIR/.github/PULL_REQUEST_TEMPLATE.md" ]]; then
  DETECTED_CODE_REVIEW="yes"; DETECTED_CODE_REVIEW_LABEL="enabled"
fi

# Detect audit trail (Entire)
DETECTED_ENTIRE=""
DETECTED_ENTIRE_LABEL=""
if command -v entire &>/dev/null && [[ -d "$PROJECT_DIR/.git" ]]; then
  if entire status 2>/dev/null | grep -qi 'enabled\|active' 2>/dev/null; then
    DETECTED_ENTIRE="yes"; DETECTED_ENTIRE_LABEL="enabled"
  fi
fi

# Is this an existing project?
IS_EXISTING="false"
[[ -n "$DETECTED_STACK" ]] && IS_EXISTING="true"

# ─────────────────────────────────────────────────────────────────────────────
# Interactive phase — confirm detected values or ask questions
# ─────────────────────────────────────────────────────────────────────────────

# Helper: ask a confirm-or-change question for detected values
# Usage: confirm_or_choose "Header" "detected_label" "default_choice" -> sets CHOICE
# Returns the choice number, or "detected" if confirmed

# --- Step 1: Project basics ---

DEFAULT_PROJECT_NAME="$(basename "$(pwd)")"
read -rp "Project name [$DEFAULT_PROJECT_NAME]: " PROJECT_NAME
PROJECT_NAME="${PROJECT_NAME:-$DEFAULT_PROJECT_NAME}"

# Auto-detect project description from common sources
DEFAULT_DESCRIPTION=""
if [[ -f package.json ]]; then
  DEFAULT_DESCRIPTION="$(grep -o '"description"[[:space:]]*:[[:space:]]*"[^"]*"' package.json 2>/dev/null | head -1 | sed 's/.*"description"[[:space:]]*:[[:space:]]*"\([^"]*\)"/\1/' || true)"
fi
if [[ -z "$DEFAULT_DESCRIPTION" && -f go.mod && -f README.md ]]; then
  DEFAULT_DESCRIPTION="$(head -5 README.md 2>/dev/null | grep -v '^#' | grep -v '^$' | head -1 || true)"
fi
if [[ -z "$DEFAULT_DESCRIPTION" && -f pyproject.toml ]]; then
  DEFAULT_DESCRIPTION="$(grep -E '^description\s*=' pyproject.toml 2>/dev/null | head -1 | sed 's/.*=\s*"\(.*\)"/\1/' || true)"
fi
if [[ -z "$DEFAULT_DESCRIPTION" && -f mix.exs ]]; then
  DEFAULT_DESCRIPTION="$(grep -o 'description:.*"[^"]*"' mix.exs 2>/dev/null | head -1 | sed 's/.*"\([^"]*\)".*/\1/' || true)"
fi
# Last resort: first non-heading, non-empty line from README
if [[ -z "$DEFAULT_DESCRIPTION" && -f README.md ]]; then
  DEFAULT_DESCRIPTION="$(grep -v '^#' README.md 2>/dev/null | grep -v '^\s*$' | head -1 || true)"
fi

if [[ -n "$DEFAULT_DESCRIPTION" ]]; then
  read -rp "Project description [$DEFAULT_DESCRIPTION]: " PROJECT_DESCRIPTION
  PROJECT_DESCRIPTION="${PROJECT_DESCRIPTION:-$DEFAULT_DESCRIPTION}"
else
  read -rp "Project description (one line): " PROJECT_DESCRIPTION
  if [[ -z "$PROJECT_DESCRIPTION" ]]; then
    PROJECT_DESCRIPTION="$PROJECT_NAME"
  fi
fi

# --- Helper: set stack commands from choice number ---
set_stack_commands() {
  case "$1" in
    1)
      STACK_NAME="node"
      TEST_CMD="npm test"
      LINT_CMD="npx eslint . && npx tsc --noEmit"
      BUILD_CMD="npm run build"
      STACK_SECTION="Node.js / TypeScript. See \`templates/stacks/node.md\` for detailed configuration."
      ;;
    2)
      STACK_NAME="go"
      TEST_CMD="go test ./..."
      LINT_CMD="go vet ./... && golangci-lint run ./..."
      BUILD_CMD="go build ./cmd/..."
      STACK_SECTION="Go. See \`templates/stacks/go.md\` for detailed configuration."
      ;;
    3)
      STACK_NAME="python"
      TEST_CMD="pytest"
      LINT_CMD="ruff check . && mypy src/"
      BUILD_CMD="python -m build"
      STACK_SECTION="Python. See \`templates/stacks/python.md\` for detailed configuration."
      ;;
    4)
      STACK_NAME="elixir"
      TEST_CMD="mix test"
      LINT_CMD="mix format --check-formatted && mix credo --strict"
      BUILD_CMD="MIX_ENV=prod mix release"
      STACK_SECTION="Elixir. See \`templates/stacks/elixir.md\` for detailed configuration."
      ;;
    5)
      STACK_NAME="other"
      STACK_SECTION="Custom stack. Update this section with your tools and conventions."
      ;;
    *) echo "Invalid choice." >&2; exit 1 ;;
  esac
}

# ─────────────────────────────────────────────────────────────────────────────
# Existing project vs Greenfield — different flows
# ─────────────────────────────────────────────────────────────────────────────

PROJECT_TYPE_DESC=""

if [[ -n "$DETECTED_STACK" ]]; then
  # ── EXISTING PROJECT ──────────────────────────────────────────────────────
  # Tech stack is a fact, not a question. "What are you building" is irrelevant.
  echo -e "${DIM}Existing project detected: ${DETECTED_STACK_LABEL}${NC}"
  set_stack_commands "$DETECTED_STACK"
else
  # ── GREENFIELD ────────────────────────────────────────────────────────────
  echo ""
  read -rp "What type of software are you building and what does it do? (examples: a corporate website, a mobile app, a report...) " PROJECT_TYPE_DESC

  echo ""
  echo -e "${BOLD}Tech stack:${NC}"
  echo "  1) Node.js / TypeScript"
  echo "  2) Go"
  echo "  3) Python"
  echo "  4) Elixir"
  echo "  5) Other (manual configuration)"
  read -rp "Choose [1]: " STACK_CHOICE
  STACK_CHOICE="${STACK_CHOICE:-1}"
  set_stack_commands "$STACK_CHOICE"

  if [[ "$STACK_NAME" == "other" ]]; then
    read -rp "Test command: " TEST_CMD
    read -rp "Lint command: " LINT_CMD
    read -rp "Build command: " BUILD_CMD
  fi
fi

# --- Team mode ---

echo ""
if [[ -n "$DETECTED_TEAM" ]]; then
  echo -e "${BOLD}Team mode:${NC} ${GREEN}$DETECTED_TEAM_LABEL${NC} detected"
  echo "  1) Keep $DETECTED_TEAM_LABEL"
  echo "  2) Change"
  read -rp "Choose [1]: " TEAM_CONFIRM
  TEAM_CONFIRM="${TEAM_CONFIRM:-1}"
  if [[ "$TEAM_CONFIRM" == "1" ]]; then
    TEAM_MODE_CHOICE="$DETECTED_TEAM"
  else
    echo ""
    echo -e "${BOLD}Team mode:${NC}"
    echo "  1) Solo      — 1 human + 1 agent, Kanban, trunk-based"
    echo "  2) Multi-agent — 1 human + agent team, Kanban, worktrees"
    echo "  3) Multi-human — PO + developers, Scrum, feature branches"
    read -rp "Choose: " TEAM_MODE_CHOICE
  fi
else
  echo -e "${BOLD}Team mode:${NC}"
  echo "  1) Solo      — 1 human + 1 agent, Kanban, trunk-based"
  echo "  2) Multi-agent — 1 human + agent team, Kanban, worktrees"
  echo "  3) Multi-human — PO + developers, Scrum, feature branches"
  read -rp "Choose [1]: " TEAM_MODE_CHOICE
  TEAM_MODE_CHOICE="${TEAM_MODE_CHOICE:-1}"
fi

case "$TEAM_MODE_CHOICE" in
  1) TEAM_MODE="Solo"; TEAM_MODE_DESC="1 human + 1 agent. Kanban. Trunk-based development." ;;
  2) TEAM_MODE="Multi-agent"; TEAM_MODE_DESC="1 human + agent team. Kanban. Worktrees from main." ;;
  3) TEAM_MODE="Multi-human"; TEAM_MODE_DESC="PO + developers. Full Scrum. Feature branches + PRs." ;;
  *) echo "Invalid choice." >&2; exit 1 ;;
esac

# --- AI coding tool ---

if [[ -n "$DETECTED_STACK" && -n "$DETECTED_TOOL" ]]; then
  # Existing project with clear tool — skip silently
  echo -e "${DIM}AI coding tool: ${DETECTED_TOOL_LABEL}${NC}"
  TOOL_CHOICE="$DETECTED_TOOL"
elif [[ -n "$DETECTED_TOOL" ]]; then
  # Greenfield but tool detected (e.g. .claude/ exists) — confirm
  echo ""
  echo -e "${BOLD}AI coding tool:${NC} ${GREEN}$DETECTED_TOOL_LABEL${NC} detected"
  read -rp "Correct? [Y/n]: " TOOL_CONFIRM
  TOOL_CONFIRM="${TOOL_CONFIRM:-Y}"
  if [[ "$TOOL_CONFIRM" =~ ^[Yy] ]]; then
    TOOL_CHOICE="$DETECTED_TOOL"
  else
    echo ""
    echo -e "${BOLD}AI coding tool:${NC}"
    echo "  1) Claude Code (recommended)"
    echo "  2) Codex CLI"
    echo "  3) Cursor CLI"
    echo "  4) Google CLI"
    echo "  5) GitHub Copilot CLI"
    echo "  6) Opencode / Generic / Other CLI"
    read -rp "Choose: " TOOL_CHOICE
  fi
else
  echo ""
  echo -e "${BOLD}AI coding tool:${NC}"
  echo "  1) Claude Code (recommended)"
  echo "  2) Codex CLI"
  echo "  3) Cursor CLI"
  echo "  4) Google CLI"
  echo "  5) GitHub Copilot CLI"
  echo "  6) Opencode / Generic / Other CLI"
  read -rp "Choose [1]: " TOOL_CHOICE
  TOOL_CHOICE="${TOOL_CHOICE:-1}"
fi

case "$TOOL_CHOICE" in
  1) TOOL_NAME="claude-code" ;;
  2) TOOL_NAME="codex" ;;
  3) TOOL_NAME="cursor" ;;
  4) TOOL_NAME="google" ;;
  5) TOOL_NAME="copilot" ;;
  6) TOOL_NAME="generic" ;;
  *) echo "Invalid choice." >&2; exit 1 ;;
esac

# --- Backlog management ---

BACKLOG_SECTION=""
BACKLOG_CHOICE=""

if [[ -n "$DETECTED_STACK" && -n "$DETECTED_BACKLOG" ]]; then
  # Existing project with detected backlog — skip silently
  echo -e "${DIM}Backlog: ${DETECTED_BACKLOG_LABEL}${NC}"
  BACKLOG_CHOICE="$DETECTED_BACKLOG"

  # Set section without prompting for URLs
  case "$DETECTED_BACKLOG" in
    3)
      BACKLOG_SECTION="## Product Backlog

PBIs are managed in Jira. This repo is the development layer.

**At session start:** use the Jira MCP or API to find tickets in the Ready column. Read description, acceptance criteria, and subtasks before starting work."
      ;;
    4)
      BACKLOG_SECTION="## Product Backlog

PBIs are managed as files in the \`backlog/\` directory. No external tool required.

**At session start:** check \`backlog/ready/\` for PBIs to work on. Read the PBI file for acceptance criteria and checklist. Move to \`backlog/in_progress/\` when you begin."
      ;;
  esac
else
  echo ""
  echo -e "${BOLD}Where do you manage requirements (Product Backlog)?${NC}"
  echo "  1) Agilar PO Companion (recommended for enterprise product management)"
  echo "  2) Agilar Chepibe (recommended for solo development & small projects)"
  echo "  3) Jira"
  echo "  4) Filesystem backlog only (built-in, no external tool needed)"
  echo "  5) Other system"
  read -rp "Choose [1]: " BACKLOG_CHOICE
  BACKLOG_CHOICE="${BACKLOG_CHOICE:-1}"
fi

if [[ -z "$BACKLOG_SECTION" ]]; then
case "$BACKLOG_CHOICE" in
  1)
    read -rp "PO Companion API URL (e.g. https://po.example.com/api/backlog): " BACKLOG_URL
    BACKLOG_SECTION="## Product Backlog

PBIs are managed in Agilar PO Companion (PO layer). This repo is the development layer.

**Backlog API:** \`$BACKLOG_URL\`

- List PBIs: \`GET $BACKLOG_URL\`
- Update status: \`PATCH $BACKLOG_URL/:id\`

**At session start:** query the API for PBIs with status \`ready\`. Read notes, acceptance criteria, and checklist before starting work. Mark \`in_progress\` when you begin."
    ;;
  2)
    read -rp "Chepibe API URL (e.g. http://server:8076/api/backlog): " BACKLOG_URL
    BACKLOG_SECTION="## Product Backlog

PBIs are managed via the Chepibe Backlog Board API.

**Backlog API:** \`$BACKLOG_URL\`

- List PBIs: \`GET $BACKLOG_URL\`
- Create: \`POST $BACKLOG_URL\` with \`{ title, status, epic, notes, checklist }\`
- Update: \`PATCH $BACKLOG_URL/:id\` with fields to change
- Reorder: \`PATCH $BACKLOG_URL/reorder\` with \`{ items: [{ id, status, priority }] }\`
- Delete: \`DELETE $BACKLOG_URL/:id\`

**IMPORTANT:** Always use the API — never edit the backlog file directly.

**At session start:** query the API for PBIs with status \`ready\`. Read notes, acceptance criteria, and checklist before starting work. Mark \`in_progress\` when you begin."
    ;;
  3)
    read -rp "Jira project URL (e.g. https://myorg.atlassian.net/browse/PROJ): " JIRA_URL
    BACKLOG_SECTION="## Product Backlog

PBIs are managed in Jira. This repo is the development layer.

**Jira project:** \`$JIRA_URL\`

**At session start:** use the Jira MCP or API to find tickets in the Ready column. Read description, acceptance criteria, and subtasks before starting work."
    ;;
  4)
    BACKLOG_SECTION="## Product Backlog

PBIs are managed as files in the \`backlog/\` directory. No external tool required.

**At session start:** check \`backlog/ready/\` for PBIs to work on. Read the PBI file for acceptance criteria and checklist. Move to \`backlog/in_progress/\` when you begin."
    ;;
  5)
    echo ""
    echo -e "${DIM}Your system needs either a REST API or an MCP server so AI agents can read and update PBIs.${NC}"
    read -rp "System name (e.g. Linear, Shortcut, Azure DevOps): " OTHER_SYSTEM_NAME
    if [[ -z "$OTHER_SYSTEM_NAME" ]]; then
      echo "System name is required." >&2
      exit 1
    fi

    echo ""
    echo -e "${BOLD}How will AI agents connect to $OTHER_SYSTEM_NAME?${NC}"
    echo "  1) REST API"
    echo "  2) MCP server"
    read -rp "Choose: " OTHER_CONNECT_CHOICE

    case "$OTHER_CONNECT_CHOICE" in
      1)
        read -rp "$OTHER_SYSTEM_NAME API URL: " OTHER_API_URL
        if [[ -z "$OTHER_API_URL" ]]; then
          echo "API URL is required for agents to access your backlog." >&2
          exit 1
        fi
        BACKLOG_SECTION="## Product Backlog

PBIs are managed in $OTHER_SYSTEM_NAME. This repo is the development layer.

**API:** \`$OTHER_API_URL\`

**At session start:** query the API for PBIs that are ready. Read acceptance criteria and checklist before starting work."
        ;;
      2)
        read -rp "MCP server package (e.g. @anthropic/mcp-server-linear): " OTHER_MCP_PKG
        if [[ -z "$OTHER_MCP_PKG" ]]; then
          echo "MCP server package is required for agents to access your backlog." >&2
          exit 1
        fi
        BACKLOG_SECTION="## Product Backlog

PBIs are managed in $OTHER_SYSTEM_NAME via MCP. This repo is the development layer.

**MCP server:** \`$OTHER_MCP_PKG\`

**At session start:** use the $OTHER_SYSTEM_NAME MCP tools to find PBIs that are ready. Read acceptance criteria and checklist before starting work."

        # Store MCP info for later config generation
        OTHER_MCP_SERVER_NAME="$(echo "$OTHER_SYSTEM_NAME" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
        ;;
      *)
        echo "Invalid choice. Agents need either an API or MCP to work with your backlog." >&2
        exit 1
        ;;
    esac
    ;;
  *)
    echo "Invalid choice." >&2
    exit 1
    ;;
esac
fi # end of BACKLOG_SECTION empty check

# --- Code review ---

echo ""
if [[ "$TEAM_MODE_CHOICE" == "3" ]]; then
  echo -e "${DIM}Code review is mandatory for multi-human teams.${NC}"
  CODE_REVIEW="yes"
elif [[ -n "$DETECTED_CODE_REVIEW" ]]; then
  echo -e "${BOLD}Code review:${NC} ${GREEN}$DETECTED_CODE_REVIEW_LABEL${NC} detected (code-reviewer agent or PR template found)"
  read -rp "Keep enabled? [Y/n]: " CR_CONFIRM
  CR_CONFIRM="${CR_CONFIRM:-Y}"
  if [[ "$CR_CONFIRM" =~ ^[Yy] ]]; then
    CODE_REVIEW="yes"
  else
    CODE_REVIEW="no"
  fi
else
  echo -e "${BOLD}Code review:${NC}"
  echo "  If you're a non-technical person, leave this disabled (TDD + verification still active)."
  echo "  If you can read and review code, enable it for an extra quality gate."
  read -rp "Enable code review? [y/N]: " CODE_REVIEW_CHOICE
  CODE_REVIEW_CHOICE="${CODE_REVIEW_CHOICE:-N}"
  case "$CODE_REVIEW_CHOICE" in
    [Yy]*) CODE_REVIEW="yes" ;;
    *) CODE_REVIEW="no" ;;
  esac
fi

# --- Audit trail ---

# Default depends on team mode: Y for teams, N for solo
if [[ "$TEAM_MODE_CHOICE" == "2" || "$TEAM_MODE_CHOICE" == "3" ]]; then
  ENTIRE_DEFAULT="Y"
  ENTIRE_PROMPT="Enable Entire? [Y/n]: "
else
  ENTIRE_DEFAULT="N"
  ENTIRE_PROMPT="Enable Entire? [y/N]: "
fi

echo ""
if [[ -n "$DETECTED_STACK" && -n "$DETECTED_ENTIRE" ]]; then
  # Existing project with Entire already active — skip silently
  echo -e "${DIM}Audit trail: Entire enabled${NC}"
  ENTIRE_ENABLED="yes"
elif [[ -n "$DETECTED_ENTIRE" ]]; then
  echo -e "${BOLD}Audit trail:${NC} ${GREEN}Entire is $DETECTED_ENTIRE_LABEL${NC}"
  read -rp "Keep enabled? [Y/n]: " ENTIRE_CONFIRM
  ENTIRE_CONFIRM="${ENTIRE_CONFIRM:-Y}"
  if [[ "$ENTIRE_CONFIRM" =~ ^[Yy] ]]; then
    ENTIRE_ENABLED="yes"
  else
    ENTIRE_ENABLED="no"
  fi
else
  echo -e "${BOLD}Audit trail:${NC} Would you like to use the \"Entire\" open source tool to log"
  echo -e "  everything the AI does? (it gets saved in your GitHub repository)"
  echo -e "  Recommended for teams; optional for solo."
  read -rp "$ENTIRE_PROMPT" ENTIRE_CHOICE
  ENTIRE_CHOICE="${ENTIRE_CHOICE:-$ENTIRE_DEFAULT}"
  case "$ENTIRE_CHOICE" in
    [Yy]*) ENTIRE_ENABLED="yes" ;;
    *) ENTIRE_ENABLED="no" ;;
  esac
fi

# --- Step 8b: CI provider (multi-agent only) ---

CI_PROVIDER="none"
if [[ "$TEAM_MODE_CHOICE" == "2" ]]; then
  echo ""
  if [[ -n "$DETECTED_CI" ]]; then
    echo -e "${BOLD}CI provider:${NC} ${GREEN}$DETECTED_CI_LABEL${NC} detected"
    read -rp "Correct? [Y/n]: " CI_CONFIRM
    CI_CONFIRM="${CI_CONFIRM:-Y}"
    if [[ "$CI_CONFIRM" =~ ^[Yy] ]]; then
      CI_PROVIDER="$(echo "$DETECTED_CI_LABEL" | tr '[:upper:]' '[:lower:]' | tr ' ' '-')"
    else
      echo ""
      echo -e "${BOLD}CI provider (for automated CI checking):${NC}"
      echo "  1) GitHub Actions"
      echo "  2) GitLab CI"
      echo "  3) None (manual CI)"
      read -rp "Choose: " CI_CHOICE
      case "$CI_CHOICE" in
        1) CI_PROVIDER="github-actions" ;;
        2) CI_PROVIDER="gitlab-ci" ;;
        *) CI_PROVIDER="none" ;;
      esac
    fi
  else
    echo -e "${BOLD}CI provider (for automated CI checking):${NC}"
    echo "  1) GitHub Actions"
    echo "  2) GitLab CI"
    echo "  3) None (manual CI)"
    read -rp "Choose [3]: " CI_CHOICE
    CI_CHOICE="${CI_CHOICE:-3}"
    case "$CI_CHOICE" in
      1) CI_PROVIDER="github-actions" ;;
      2) CI_PROVIDER="gitlab-ci" ;;
      *) CI_PROVIDER="none" ;;
    esac
  fi
fi


# ─────────────────────────────────────────────────────────────────────────────
# Generate files
# ─────────────────────────────────────────────────────────────────────────────

echo ""
echo -e "${CYAN}Generating project files...${NC}"

# Create backlog directories (always, regardless of external tool)
mkdir -p "$PROJECT_DIR/backlog/ready" "$PROJECT_DIR/backlog/in_progress" "$PROJECT_DIR/backlog/done"
touch "$PROJECT_DIR/backlog/.gitkeep" "$PROJECT_DIR/backlog/ready/.gitkeep" "$PROJECT_DIR/backlog/in_progress/.gitkeep" "$PROJECT_DIR/backlog/done/.gitkeep"
echo -e "  ${GREEN}+${NC} backlog/ (filesystem backlog: ready/, in_progress/, done/)"

# Create .claude/skills/ directory for Claude Code
if [[ "$TOOL_NAME" == "claude-code" ]]; then
  SKILLS_DIR="$PROJECT_DIR/.claude/skills"
  mkdir -p "$SKILLS_DIR"

  # Copy all skill implementations
  IMPL_DIR="$SCRIPT_DIR/implementations/claude-code"
  if [[ -d "$IMPL_DIR" ]]; then
    for skill_file in "$IMPL_DIR"/*.md; do
      if [[ -f "$skill_file" ]]; then
        cp "$skill_file" "$SKILLS_DIR/$(basename "$skill_file")"
        echo -e "  ${GREEN}+${NC} .claude/skills/$(basename "$skill_file")"
      fi
    done
  fi
fi

# Create .claude/agents/ for multi-agent mode (Claude Code only)
